<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.livingroomcam.server</string>
  <key>ProgramArguments</key>
  <array>
    <string>/ABSOLUTE/PATH/TO/LivingRoomCam/.venv/bin/python</string>
    <string>-m</string>
    <string>livingroomcam.server</string>
    <string>/ABSOLUTE/PATH/TO/LivingRoomCam/config/server.local.json</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/ABSOLUTE/PATH/TO/LivingRoomCam</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PYTHONPATH</key>
    <string>/ABSOLUTE/PATH/TO/LivingRoomCam/src</string>
  </dict>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/tmp/livingroomcam-server.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/livingroomcam-server.err</string>
</dict>
</plist>
